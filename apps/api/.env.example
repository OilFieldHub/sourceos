NODE_ENV=development
PORT=3001

# DB_TYPE=sqlite for local dev (no Docker/Postgres needed) or postgres for
# staging/prod (Phase 10 deploy). DB_PATH is only read when DB_TYPE=sqlite;
# the DB_HOST..DB_DATABASE vars are only read when DB_TYPE=postgres.
DB_TYPE=sqlite
DB_PATH=./data/oilfieldhub.sqlite

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=oilfieldhub
DB_PASSWORD=oilfieldhub
DB_DATABASE=oilfieldhub

# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me
JWT_EXPIRES_IN=8h

WEB_ORIGIN=http://localhost:3000
